{
  "name": "astro-polyglot-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for astro-polyglot — multi-language documentation plugin for Astro/Starlight",
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.32.1"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm --filter astro-polyglot build",
    "dev": "pnpm --filter astro-polyglot dev",
    "test": "pnpm --filter astro-polyglot test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "pnpm -r format",
    "clean": "pnpm --filter astro-polyglot clean",
    "docs:dev": "pnpm --filter astro-polyglot-docs dev",
    "docs:build": "pnpm --filter astro-polyglot-docs build",
    "docs:preview": "pnpm --filter astro-polyglot-docs preview"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "@biomejs/biome": "catalog:"
  }
}
