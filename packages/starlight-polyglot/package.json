{
  "name": "starlight-polyglot",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Starlight plugin to generate documentation from any programming language using its native toolchain.",
  "author": "Dylan A Mordaunt <dylan@mordaunt.dev>",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup index.ts --format esm,cjs --dts --clean --shims --define.import.meta.dirname=__dirname",
    "dev": "tsup index.ts --format esm,cjs --dts --watch --shims --define.import.meta.dirname=__dirname",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:properties": "vitest run tests/properties/ --reporter=verbose",
    "test:fuzz": "vitest run tests/fuzz/ --reporter=verbose",
    "test:bench": "vitest bench tests/benches/ --reporter=verbose",
    "test:mutation": "stryker run stryker.config.json",
    "test:e2e": "playwright test",
    "test:security": "echo 'Security checks: ensure no secrets in source' && grep -rni 'api[_-]key\\|secret\\|password\\|token\\|credential' --include='*.ts' --include='*.json' . --exclude-dir=node_modules --exclude-dir=dist --exclude-dir=.stryker-tmp || echo '✓ No secrets found in source'",
    "test:all": "pnpm test && pnpm test:coverage && pnpm test:properties && pnpm test:fuzz",
    "test:ci": "pnpm test && pnpm test:properties --reporter=verbose && pnpm test:fuzz --reporter=verbose && pnpm test:coverage",
    "lint": "eslint . --cache --max-warnings=0",
    "format": "prettier --write '**/*.{ts,json,md}'",
    "format:check": "prettier --check '**/*.{ts,json,md}'",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .tsbuildinfo coverage .stryker-tmp",
    "size": "size-limit",
    "prepublish": "pnpm build",
    "release": "changeset publish"
  },
  "dependencies": {
    "github-slugger": "^2.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@faker-js/faker": "catalog:",
    "@fast-check/vitest": "catalog:",
    "@playwright/test": "catalog:",
    "@stryker-mutator/core": "catalog:",
    "@stryker-mutator/vitest-runner": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "fast-check": "catalog:",
    "prettier": "catalog:",
    "size-limit": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@astrojs/starlight": ">=0.39.0",
    "astro": ">=6.0.0",
    "typedoc": ">=0.28.0",
    "typedoc-plugin-markdown": ">=4.6.0"
  },
  "peerDependenciesMeta": {
    "typedoc": {
      "optional": true
    },
    "typedoc-plugin-markdown": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.32.1",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "files": [
    "dist/",
    "handlers/",
    "core/",
    "scripts/*.R",
    "scripts/*.dart",
    "scripts/*.do",
    "scripts/*.exs",
    "scripts/*.fsx",
    "scripts/*.go",
    "scripts/*.jl",
    "scripts/*.php",
    "scripts/*.py",
    "scripts/*.rb",
    "scripts/*.sas",
    "scripts/*.scala",
    "scripts/*.ts",
    "scripts/rust_extract/Cargo.lock",
    "scripts/rust_extract/Cargo.toml",
    "scripts/rust_extract/src/",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "starlight",
    "plugin",
    "polyglot",
    "documentation",
    "astro",
    "python",
    "typescript",
    "rust",
    "r",
    "julia",
    "csharp",
    "go"
  ],
  "homepage": "https://github.com/edithatogo/starlight-polyglot",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edithatogo/starlight-polyglot.git",
    "directory": "packages/starlight-polyglot"
  },
  "bugs": "https://github.com/edithatogo/starlight-polyglot/issues"
}
